{
  "name": "solo-vault-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.908.0"
  },
  "scripts": {
    "iac": "node ./node_modules/tsx/dist/cli.mjs infra/scripts/deploy.ts",
    "iac:pipeline": "node ./node_modules/tsx/dist/cli.mjs infra/scripts/deploy-pipeline.ts",
    "deploy": "npm run iac -- --env dev",
    "deploy:staging": "npm run iac -- --env staging",
    "deploy:pipeline": "npm run iac:pipeline -- --env dev",
    "deploy:pipeline:staging": "npm run iac:pipeline -- --env staging",
    "destroy": "npm run iac -- --action destroy --env dev",
    "destroy:staging": "npm run iac -- --action destroy --env staging",
    "destroy:pipeline": "npm run iac:pipeline -- --action destroy --env dev --confirm-destroy solo-vault",
    "destroy:pipeline:staging": "npm run iac:pipeline -- --action destroy --env staging --confirm-destroy solo-vault"
  }
}
